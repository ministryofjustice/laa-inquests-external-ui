{% extends "base.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block content %}

<div class="govuk-width-container">
  {{ govukBackLink({
    text: "Back",
    href: "/claim"
  }) }}
  <main class="govuk-main-wrapper">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-l">Which case do you want to make a claim for?</h1>
        {{ govukTable({
          head: [
            { text: "Case Reference" },
            { text: "Client Name" },
            { text: "Client Date of Birth" },
            { text: "Date Submitted" },
            { text: "Firm Name" },
            { text: "Firm Number" },
            { text: "Case Status" }
          ],
          rows: cases if cases else []
        }) }}
      </div>
    </div>
  </main>
</div>

{% endblock %}
