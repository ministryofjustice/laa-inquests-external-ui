{% extends "base.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}


{% block content %}
<div class="govuk-width-container">
    {{ govukBackLink({
        text: "Back",
        href: "/apply/deceased-details/dod"
    }) }}
    <main class="govuk-main-wrapper">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-half">
                {% if errorSummaries.dateOfBirthInputError %}
                {{ govukErrorSummary({
                    titleText: "There is a problem",
                    errorList: [
                        {
                            text: errorSummaries.dateOfBirthInputError.text,
                            href: "#deceased-date-of-birth"
                        }
                    ]
                }) }}
                {% endif %}
                <h2 class="govuk-heading-l">What was their date of birth?</h2>
                <form data-testid="deceased-date-of-birth-form" action="/apply/deceased-details/dob" method="post">
                <input type="hidden" name="_csrf" value={{csrfToken}} />
                {{ govukDateInput({
                        id: "deceased-date-of-birth",
                        namePrefix: "deceased-date-of-birth",
                        fieldset: {
                            legend: {
                                text: "Date of birth",
                                classes: "govuk-fieldset__legend--s"
                            }
                        },
                        errorMessage: errorSummaries.dateOfBirthInputError,
                        items: [
                            {
                                classes: "govuk-input--width-2",
                                name: "day",
                                value: deceasedDetails.dateOfBirthDay
                            },
                            {
                                classes: "govuk-input--width-2",
                                name: "month",
                                value: deceasedDetails.dateOfBirthMonth
                            },
                            {
                                classes: "govuk-input--width-4",
                                name: "year",
                                value: deceasedDetails.dateOfBirthYear
                            }
                        ]
                    }) }}
                    {{ govukButton({
                        text: "Continue"
                    }) }}
                </form>
            </div>
        </div>
    </main>
</div>
{% endblock %}