{% extends "base.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% block content %}

<div class="govuk-width-container">
    {{ govukBackLink({
        text: "Back",
        href: "/apply/deceased-details/name"
    }) }}
    <main class="govuk-main-wrapper">
        <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
            <h2 class="govuk-heading-l">What was their date of death?</h2>
            <form data-testid="deceased-date-of-death-form" action="/apply/deceased-details/dod" method="post">
                {{ govukDateInput({
                        id: "date-of-death",
                        namePrefix: "date-of-death",
                        fieldset: {
                            legend: {
                                text: "Date of death",
                                classes: "govuk-fieldset__legend--s"
                            }
                        }
                    }) }}
            </form>
        </div>
    </main>
</div>
{% endblock %}